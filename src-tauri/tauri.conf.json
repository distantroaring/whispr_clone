{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Whispr Clone",
  "version": "0.1.0",
  "identifier": "com.whisprclone.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Whispr Clone",
        "width": 900,
        "height": 680,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "nsis"],
    "icon": [
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Local-first dictation utility",
    "longDescription": "A free local-first dictation app powered by whisper.cpp and optional Ollama cleanup."
  }
}
